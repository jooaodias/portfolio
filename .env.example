# Statsig SDK Key
NEXT_PUBLIC_STATSIG_CLIENT_KEY=your_statsig_client_key_here

# API URL (with /api prefix — used for blog posts and other endpoints)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Backend origin URL (without /api — used by the health check on /status)
# If not set, it is derived automatically from NEXT_PUBLIC_API_URL by stripping /api.
# NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Base URL for the site
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Google Analytics ID
NEXT_PUBLIC_GA4_ANALYTICS=your_ga4_id_here
